{
  "version": "1.0.0",
  "updated": "2026-07-12",
  "source": "jax-a11y/skintwin-ecosystem-design",
  "manifestSchema": "https://raw.githubusercontent.com/jax-a11y/skintwin-ecosystem-design/main/schemas/ecosystem-manifest.schema.json",
  "description": "Live registry of the SkinTwin-AI ecosystem. Maps every active repository to its architectural layer, role, contracts, and events. Each repo carries its own copy at .skintwin/manifest.json.",
  "layers": {
    "governance": "Architecture, contracts, CI/CD standards, and design documentation",
    "cognitive": "AI/cognitive services: neuro-symbolic reasoning, skin models, agents (Alchemist Engine spec)",
    "business-apps": "Business domain services: customer & org management, LMS",
    "commerce-runtime": "Shopify app surfaces: embedded admin apps, operator dashboards, marketplace channel",
    "commerce-surface": "Customer-facing storefronts and buyer frontends",
    "integration": "Platform connectors, unified data models, webhook routing, API gateway",
    "erp-federation": "Federated enterprise data: procurement, supplier intelligence, inventory/finance sync",
    "ml-training": "Model and content training pipelines",
    "observability": "Dashboards and monitoring of the cognitive/business stack",
    "marketing": "Brand sites and static archives",
    "dev-tooling": "Developer/orchestration tooling for the ecosystem"
  },
  "contracts": [
    {
      "id": "cognitive-api",
      "type": "rest",
      "pathPrefix": "/api/cognitive/*",
      "provider": "rzonedevops/neuro-symbolic-core",
      "consumers": [
        "jax-a11y/skintwin-customer-portal",
        "rzonedevops/regima-training-lms",
        "jax-a11y/skintwin-asi",
        "rzonedevops/regima-cognitive-dashboard"
      ],
      "description": "Skin analysis, recommendations, personalization from the neuro-symbolic cognitive layer"
    },
    {
      "id": "integration-api",
      "type": "rest",
      "pathPrefix": "/api/integrations/*",
      "provider": "jax-a11y/skintwin-integration-hub",
      "consumers": [
        "jax-a11y/skintwin-salon",
        "jax-a11y/skintwin-customer-portal",
        "rzonedevops/regima-training-lms",
        "rzonedevops/regima-salon-suite",
        "jax-a11y/skintwin-ordering-agent"
      ],
      "description": "Unified gateway to Wix/OpenCart/Shopify B2B: health, sync (appointments/clients/products), B2B companies"
    },
    {
      "id": "user-api",
      "type": "rest",
      "pathPrefix": "/api/users/*",
      "provider": "jax-a11y/skintwin-customer-portal",
      "consumers": [
        "rzonedevops/regima-training-lms",
        "rzonedevops/regima-salon-suite"
      ],
      "description": "Users, organizations, tenants, roles (Customer & Org Service); issues JWTs validated at the gateway"
    },
    {
      "id": "lms-api",
      "type": "rest",
      "pathPrefix": "/api/lms/*",
      "provider": "rzonedevops/regima-training-lms",
      "consumers": [
        "jax-a11y/skintwin-customer-portal",
        "rzonedevops/regima-train-nnllms"
      ],
      "description": "Courses, enrollment, progress, certification; xAPI/SCORM/LTI interop"
    },
    {
      "id": "procurement-api",
      "type": "rest",
      "pathPrefix": "/api/erp/* (ERP federation domain)",
      "provider": "rzonedevops/skinsource-pro",
      "consumers": [
        "jax-a11y/skintwin-workbench",
        "jax-a11y/skintwin-asi"
      ],
      "description": "Ingredient sourcing, suppliers, RFQ procurement lifecycle \u2014 concrete procurement domain of the Federated ERP layer"
    },
    {
      "id": "supplier-dataset",
      "type": "dataset",
      "pathPrefix": null,
      "provider": "rzonedevops/pcsdbx1",
      "consumers": [
        "rzonedevops/skinsource-pro"
      ],
      "description": "~1,316 curated supplier-intelligence JSON listings (schema v1.0) for cosmetics manufacturing"
    },
    {
      "id": "marketplace-admin-graphql",
      "type": "graphql",
      "pathPrefix": "/graphql",
      "provider": "jax-a11y/skintwin-marketplace-admin-app",
      "consumers": [
        "jax-a11y/skintwin-marketplaces-buyer-app"
      ],
      "description": "Apollo GraphQL BFF for the marketplace channel (shops, products, orders)"
    },
    {
      "id": "alchemist-engine-spec",
      "type": "spec",
      "pathPrefix": null,
      "provider": "jax-a11y/skintwin-workbench",
      "consumers": [
        "jax-a11y/skintwin-asi",
        "rzonedevops/neuro-symbolic-core",
        "rzonedevops/skin7nn"
      ],
      "description": "Alchemist Engine cognitive architecture spec and MRP/workbench OpenAPI contracts"
    },
    {
      "id": "event-contracts",
      "type": "schema",
      "pathPrefix": "contracts/events/",
      "provider": "jax-a11y/skintwin-ecosystem-design",
      "consumers": [
        "*"
      ],
      "description": "JSON Schemas for the ecosystem event envelope and core topics"
    },
    {
      "id": "reusable-ci",
      "type": "ci",
      "pathPrefix": ".github/workflows/",
      "provider": "jax-a11y/skintwin-ecosystem-design",
      "consumers": [
        "*"
      ],
      "description": "Reusable workflow_call CI templates: ci-node, ci-python, ci-e2e, ci-contracts, ci-security, ci-container, ci-release"
    }
  ],
  "events": {
    "envelope": "contracts/events/envelope.schema.json",
    "conventions": "Dot-separated lowercase entity.pastTenseVerb (user.created, order.placed); service-namespaced for service-emitted outcomes (lms.user.provisioned, erp.product.synced). Envelope: {id: evt_<unique> idempotency key, type, payload (camelCase), partitionKey}. Retry with retryCount, DLQ at /api/events/dlq, ordering per partitionKey.",
    "topics": {
      "user.created": {
        "publishers": [
          "jax-a11y/skintwin-customer-portal"
        ],
        "subscribers": [
          "rzonedevops/regima-training-lms",
          "jax-a11y/skintwin-integration-hub"
        ],
        "payloadSchema": "contracts/events/user.created.schema.json"
      },
      "order.placed": {
        "publishers": [
          "jax-a11y/skintwin-salon",
          "jax-a11y/skintwin-ordering-agent"
        ],
        "subscribers": [
          "jax-a11y/skintwin-customer-portal",
          "jax-a11y/skintwin-integration-hub"
        ],
        "payloadSchema": "contracts/events/order.placed.schema.json"
      },
      "order.created": {
        "publishers": [
          "jax-a11y/skintwin-integration-hub"
        ],
        "subscribers": [
          "jax-a11y/skintwin-customer-portal"
        ],
        "payloadSchema": "contracts/events/order.created.schema.json"
      },
      "order.paid": {
        "publishers": [
          "jax-a11y/skintwin-integration-hub"
        ],
        "subscribers": [
          "jax-a11y/skintwin-customer-portal",
          "rzonedevops/skinsource-pro"
        ],
        "payloadSchema": "contracts/events/order.paid.schema.json"
      },
      "product.updated": {
        "publishers": [
          "jax-a11y/skintwin-integration-hub"
        ],
        "subscribers": [
          "jax-a11y/skintwin-asi",
          "jax-a11y/skintwin-marketplaces-buyer-app"
        ],
        "payloadSchema": "contracts/events/product.updated.schema.json"
      },
      "inventory.updated": {
        "publishers": [
          "rzonedevops/skinsource-pro",
          "jax-a11y/skintwin-integration-hub"
        ],
        "subscribers": [
          "jax-a11y/skintwin-asi",
          "rzonedevops/regima-salon-suite"
        ],
        "payloadSchema": "contracts/events/inventory.updated.schema.json"
      },
      "appointment.created": {
        "publishers": [
          "jax-a11y/skintwin-integration-hub",
          "jax-a11y/skintwin-salon"
        ],
        "subscribers": [
          "jax-a11y/skintwin-customer-portal"
        ],
        "payloadSchema": "contracts/events/appointment.created.schema.json"
      },
      "appointment.updated": {
        "publishers": [
          "jax-a11y/skintwin-integration-hub"
        ],
        "subscribers": [
          "jax-a11y/skintwin-customer-portal"
        ],
        "payloadSchema": "contracts/events/appointment.updated.schema.json"
      },
      "course.completed": {
        "publishers": [
          "rzonedevops/regima-training-lms"
        ],
        "subscribers": [
          "jax-a11y/skintwin-customer-portal"
        ],
        "payloadSchema": "contracts/events/course.completed.schema.json"
      },
      "certification.awarded": {
        "publishers": [
          "rzonedevops/regima-training-lms"
        ],
        "subscribers": [
          "jax-a11y/skintwin-customer-portal"
        ],
        "payloadSchema": "contracts/events/certification.awarded.schema.json"
      }
    }
  },
  "serviceEnv": {
    "SKINTWIN_GATEWAY_URL": "Base URL of the API Gateway (single public entry point)",
    "SKINTWIN_INTEGRATION_HUB_URL": "Base URL of the integration hub (default http://localhost:5000)",
    "SKINTWIN_COGNITIVE_API_URL": "Base URL of the cognitive service (/api/cognitive/*)",
    "SKINTWIN_USER_API_URL": "Base URL of the Customer & Org service (/api/users/*)",
    "SKINTWIN_LMS_API_URL": "Base URL of the LMS service (/api/lms/*)",
    "SKINTWIN_EVENT_BUS_URL": "Base URL of the event bus facade (/api/events/*)"
  },
